<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/analysis_item_background"
    android:backgroundTint="@color/bg_secondary"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAnalysisName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analysis Name"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAnalysisStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvAnalysisPercentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="85%"
        android:textColor="@color/accent_primary"
        android:textSize="18sp"
        android:textStyle="bold"/>

</LinearLayout>
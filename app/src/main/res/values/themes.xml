<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.FaceMuse" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/bg_secondary</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="colorOnSurfaceVariant">@color/text_primary</item>
        <item name="colorSecondaryContainer">@android:color/transparent</item>

    </style>

    <style name="Theme.FaceMuse" parent="Base.Theme.FaceMuse" />

    <style name="Theme.FaceMuse.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="QuickQuestionButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@color/highlight_soft</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>
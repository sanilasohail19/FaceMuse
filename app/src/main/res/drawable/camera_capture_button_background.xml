<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/bg_main"/>
        </shape>
    </item>

    <item android:left="6dp" android:right="6dp" android:top="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <gradient
                android:angle="45"
                android:startColor="@color/accent_primary"
                android:endColor="@color/highlight_soft"
                android:type="linear" />
            <stroke android:width="1dp" android:color="@color/divider_line" />
        </shape>
    </item>
</layer-list>